# Base URL for the Django API (no trailing path segment after /api if your routes are /api/accounts/...)
# Production (Vercel): set the same keys in Project Settings → Environment Variables, then redeploy.
# Must be HTTPS if the site is served over HTTPS (mixed content is blocked on mobile).
VITE_API_URL=https://your-api.example.com/api
VITE_API_BASE_URL=https://your-api.example.com
